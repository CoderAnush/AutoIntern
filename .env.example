# ==================== REQUIRED FOR PRODUCTION ====================

# Database Connection URL (PostgreSQL with asyncpg)
# Format: postgresql+asyncpg://user:password@host:port/database
# Example: postgresql+asyncpg://autointern:mypassword@db.railway.app:5432/autointern
DATABASE_URL=postgresql+asyncpg://autointern:change-me@localhost:5432/autointern

# JWT Secret Key (generate with: openssl rand -hex 32)
# Must be random, at least 32 characters
SECRET_KEY=your-random-secret-key-64-characters-minimum-change-this-in-production

# Redis URL (for rate limiting, caching)
# Format: redis://[:password]@host:port/database
# Example: redis://default:password@redis.railway.app:6379/0
REDIS_URL=redis://localhost:6379/0

# ==================== OPTIONAL - EMAIL NOTIFICATIONS ====================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=noreply@yourdomain.com
SENDER_PASSWORD=your-app-specific-email-password

# ==================== OPTIONAL - FILE STORAGE ====================

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=resumes

# ==================== APPLICATION SETTINGS ====================

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MIN_PASSWORD_LENGTH=8
REQUIRE_SPECIAL_CHARS=true
REQUIRE_NUMBERS=true
REQUIRE_UPPERCASE=true
REQUIRE_LOWERCASE=true

# ==================== CORS CONFIGURATION ====================

# For development: ["*"]
# For production: ["https://yourdomain.com", "https://www.yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000"]

# ==================== DATABASE MIGRATION ====================

# Set to true only in local dev to auto-create tables on startup
MIGRATE_ON_START=false

# ==================== DEPLOYMENT NOTES ====================

# RAILWAY DEPLOYMENT:
# 1. Create with: railway init
# 2. Set DATABASE_URL from PostgreSQL add-on: railway variable add DATABASE_URL "..."
# 3. Set SECRET_KEY: railway variable add SECRET_KEY "$(openssl rand -hex 32)"
# 4. Set REDIS_URL from Redis add-on: railway variable add REDIS_URL "..."
# 5. Deploy: railway up
# 6. Check: railway logs --follow

# HEROKU DEPLOYMENT:
# 1. Create: heroku create autointern-api
# 2. Add PostgreSQL: heroku addons:create heroku-postgresql:hobby-dev
# 3. Add Redis: heroku addons:create heroku-redis:premium-0
# 4. Set SECRET_KEY: heroku config:set SECRET_KEY="..."
# 5. Deploy: git push heroku main
# 6. Check: heroku logs --tail

# KEY GENERATION:
# Linux/Mac: openssl rand -hex 32
# Windows: python -c "import secrets; print(secrets.token_hex(32))"

